APP_NAME=Cloud Cost Intelligence
ENVIRONMENT=production
DATA_MODE=live
DATABASE_URL=sqlite:///C:/data/cloud_cost_intelligence.db
SESSION_SECRET_KEY=replace-with-a-long-random-secret
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-this
BOOTSTRAP_ADMIN_NAME=Platform Admin
APP_BASE_URL=https://your-app.example.com
STRUCTURED_LOGS=true
ALERTING_ENABLED=true
ALERTING_WEBHOOK_URL=https://hooks.example.com/cloud-cost-alerts
ALERT_ON_JOB_FAILURE=true
ALERT_ON_ANOMALY_DETECTED=true
AWS_ENABLED=true
AWS_REGION=us-east-1
GCP_ENABLED=false
OPTIMIZATION_DRY_RUN=true
SCHEDULER_ENABLED=true
