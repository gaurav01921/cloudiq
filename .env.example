APP_NAME=Cloud Cost Intelligence
ENVIRONMENT=development
DATA_MODE=live
DATABASE_URL=sqlite:///C:/Temp/cloud-cost-intelligence/cloud_cost_intelligence.db
SESSION_SECRET_KEY=replace-with-a-long-random-secret
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BOOTSTRAP_ADMIN_NAME=Platform Admin
APP_BASE_URL=http://127.0.0.1:8000
DEFAULT_CURRENCY=USD
STRUCTURED_LOGS=true
AWS_REGION=eu-north-1
AWS_ENABLED=true
AWS_ACCOUNT_ID=
AWS_COST_ANOMALY_THRESHOLD=0.98
GCP_ENABLED=true
GCP_PROJECT_ID=
GCP_BILLING_EXPORT_TABLE=
GCP_COST_ANOMALY_THRESHOLD=0.98
OPTIMIZATION_DRY_RUN=true
OPTIMIZATION_MIN_MONTHLY_SAVINGS=5
OPTIMIZATION_REQUIRE_EXPLICIT_APPROVAL=true
OPTIMIZATION_MAX_ACTIONS_PER_RUN=3
OPTIMIZATION_BLOCK_ROOT_CREDENTIALS=true
OPTIMIZATION_PROTECTED_TAG_KEYS=DoNotStop,DoNotDelete,Protected,Critical,Production
OPTIMIZATION_PROTECTED_TAG_VALUES=true,yes,1,prod,production,critical
INGESTION_LOOKBACK_DAYS=30
RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_SECONDS=1.0
ALERTING_ENABLED=false
ALERTING_WEBHOOK_URL=
ALERT_ON_JOB_FAILURE=true
ALERT_ON_ANOMALY_DETECTED=false
SCHEDULER_ENABLED=true
SCHEDULER_CRON_MINUTE=15
